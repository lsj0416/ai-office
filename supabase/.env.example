# Supabase 로컬 개발 환경변수
# 복사 후 .env 로 이름 변경하여 사용
# cp supabase/.env.example supabase/.env
# 주의: supabase/.env 는 .gitignore에 포함되어 있으므로 커밋되지 않습니다

# Supabase Studio에서 AI 기능 사용 시 필요 (config.toml: studio.openai_api_key)
OPENAI_API_KEY=

# SMS 인증 사용 시 필요 (config.toml: auth.sms.twilio)
# SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=
